/* ── Reset & Variables ─────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:        #0d1117;
  --surface:   #161b22;
  --surface2:  #21262d;
  --border:    #30363d;
  --text:      #e6edf3;
  --muted:     #8b949e;
  --accent:    #58a6ff;
  --green:     #3fb950;
  --yellow:    #d29922;
  --red:       #f85149;
  --radius:    8px;
  --header-h:  56px;
  --shadow:    0 8px 32px rgba(0,0,0,.5);
}

html { font-size: 16px; }

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
  line-height: 1.5;
}

/* ── App Layout (Sidebar + Main) ──────────────────────── */
#app-layout {
  display: flex;
  height: 100vh;
  width: 100vw;
  overflow: hidden;
}

#sidebar {
  width: 260px;
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  z-index: 100;
}

.sidebar-brand {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 20px;
  border-bottom: 1px solid var(--border);
}

.brand-name {
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: .2px;
}

.sidebar-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 16px 12px;
}

.nav-section {
  margin-top: 24px;
}

.nav-section h4 {
  font-size: 0.75rem;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 8px;
  padding: 0 8px;
}

.nav-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.nav-item {
  padding: 8px 12px;
  border-radius: var(--radius);
  color: var(--text);
  cursor: pointer;
  font-size: 0.9rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: background 0.2s;
}

.nav-item:hover {
  background: var(--surface2);
}

.nav-item.active {
  background: var(--accent);
  color: #fff;
  font-weight: 500;
}

#main-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--bg);
}

.tab-pane {
  display: none;
  flex: 1;
  overflow-y: auto;
  padding: 24px;
}

.tab-pane.active {
  display: flex;
  flex-direction: column;
}

.tab-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
}

.tab-header h2 {
  font-size: 1.5rem;
  font-weight: 600;
}

.tab-actions {
  display: flex;
  gap: 12px;
}

.config-container {
  max-width: 600px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px;
}

/* ROS status pill */
.ros-status {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 8px 12px;
  border-radius: var(--radius);
  background: var(--surface2);
  font-size: .8rem;
  color: var(--muted);
  margin: 16px 12px 0 12px;
}

.ros-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--muted);
  flex-shrink: 0;
  transition: background .3s, box-shadow .3s;
}

.ros-dot.ros-connected {
  background: var(--green);
  box-shadow: 0 0 0 2px rgba(63,185,80,.25);
  animation: ros-pulse 2.5s ease-in-out infinite;
}

.ros-dot.ros-error    { background: var(--red);    box-shadow: 0 0 6px var(--red); }
.ros-dot.ros-degraded { background: var(--yellow); box-shadow: 0 0 6px var(--yellow); }

@keyframes ros-pulse {
  0%, 100% { box-shadow: 0 0 0 2px rgba(63,185,80,.25); }
  50%       { box-shadow: 0 0 0 5px rgba(63,185,80,.1); }
}

/* ── Grid ─────────────────────────────────────────────── */
.widget-grid {
  padding: 20px;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(500px, 1fr));
  gap: 16px;
  align-content: start;
}

/* Empty dashboard placeholder */
.empty-dashboard {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 100px 24px;
  color: var(--muted);
  text-align: center;
}

.empty-dashboard svg { opacity: .25; }
.empty-dashboard h2  { font-size: 1.05rem; color: var(--text); font-weight: 600; }
.empty-dashboard p   { font-size: .83rem; max-width: 380px; }

/* ── Widget Card ──────────────────────────────────────── */
.widget {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-height: 360px;
  transition: border-color .2s, box-shadow .2s;
}

.widget:hover {
  border-color: rgba(88,166,255,.25);
  box-shadow: 0 0 0 1px rgba(88,166,255,.1);
}

/* Widget header */
.widget-header {
  padding: 11px 14px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  flex-shrink: 0;
}

.widget-info {
  display: flex;
  flex-direction: column;
  gap: 1px;
  min-width: 0;
}

.widget-title {
  font-size: .87rem;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.widget-stats {
  font-size: .7rem;
  color: var(--muted);
}

.widget-actions {
  display: flex;
  gap: 3px;
  flex-shrink: 0;
}

/* Widget body */
.widget-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 12px 14px;
  gap: 10px;
  min-height: 0;
}

/* Legend */
.widget-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  flex-shrink: 0;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: .72rem;
  color: var(--text);
}

.legend-swatch {
  width: 20px;
  height: 3px;
  border-radius: 2px;
  flex-shrink: 0;
}

.legend-field {
  color: var(--muted);
  font-size: .68rem;
}

/* Canvas container */
.canvas-container {
  flex: 1;
  position: relative;
  min-height: 240px;
}

.canvas-container canvas {
  position: absolute;
  inset: 0;
  width: 100% !important;
  height: 100% !important;
}

.widget-empty-state {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  color: var(--muted);
  font-size: .8rem;
  opacity: .45;
  pointer-events: none;
}

/* Paused banner */
.widget-paused-banner {
  display: none;
  position: absolute;
  top: 8px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(88,166,255,.15);
  border: 1px solid rgba(88,166,255,.35);
  color: var(--accent);
  font-size: .72rem;
  font-weight: 600;
  padding: 3px 10px;
  border-radius: 20px;
  pointer-events: none;
  z-index: 2;
}

.widget.is-paused .widget-paused-banner { display: block; }

/* ── Buttons (global) ─────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 7px 15px;
  border-radius: var(--radius);
  border: none;
  font-size: .82rem;
  font-weight: 600;
  cursor: pointer;
  transition: filter .15s, opacity .15s;
  white-space: nowrap;
}

.btn:hover  { filter: brightness(1.15); }
.btn:active { opacity: .85; }

.btn-primary { background: var(--accent); color: #fff; }

.btn-ghost {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--muted);
}

.btn-ghost:hover {
  color: var(--text);
  border-color: var(--accent);
  background: var(--surface2);
}

/* Widget icon buttons */
.wbtn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  font-size: .8rem;
  border-radius: 6px;
  border: 1px solid transparent;
  background: transparent;
  color: var(--muted);
  cursor: pointer;
  transition: background .15s, color .15s, border-color .15s;
}

.wbtn:hover {
  background: var(--surface2);
  color: var(--text);
  border-color: var(--border);
}

.wbtn.danger:hover {
  background: rgba(248,81,73,.12);
  color: var(--red);
  border-color: rgba(248,81,73,.4);
}

.wbtn.active {
  color: var(--accent);
  background: rgba(88,166,255,.1);
  border-color: rgba(88,166,255,.3);
}

/* ── Modal ────────────────────────────────────────────── */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.65);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

.modal-overlay.hidden { display: none; }

.modal {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  width: 100%;
  max-width: 660px;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow);
  animation: modal-in .18s cubic-bezier(.34,1.56,.64,1);
}

.modal-sm { max-width: 480px; }

@keyframes modal-in {
  from { opacity: 0; transform: scale(.94) translateY(10px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

.modal-header {
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  flex-shrink: 0;
}

.modal-header h2 { font-size: .95rem; font-weight: 700; }

.modal-close {
  background: transparent;
  border: none;
  color: var(--muted);
  font-size: 1rem;
  cursor: pointer;
  padding: 4px 6px;
  border-radius: 5px;
  line-height: 1;
  transition: color .15s, background .15s;
}

.modal-close:hover { color: var(--text); background: var(--surface2); }

.modal-body {
  padding: 20px;
  overflow-y: auto;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.modal-footer {
  padding: 14px 20px;
  border-top: 1px solid var(--border);
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

/* ── Alerts ───────────────────────────────────────────── */
.alert {
  padding: 12px 16px;
  border-radius: var(--radius);
  font-size: .82rem;
  line-height: 1.5;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.alert.hidden {
  display: none !important;
}

.alert-warning {
  background: rgba(210, 153, 34, 0.1);
  border: 1px solid var(--yellow);
  color: var(--yellow);
}

/* ── Form elements ────────────────────────────────────── */
.form-group {
  display: flex;
  flex-direction: column;
  gap: 5px;
  flex: 1;
}

.form-group label {
  font-size: .74rem;
  color: var(--muted);
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 4px;
}

.label-hint {
  font-weight: 400;
  opacity: .7;
}

.form-row {
  display: flex;
  gap: 12px;
  align-items: flex-end;
}

input[type="text"],
input[type="number"],
select {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text);
  padding: 7px 10px;
  font-size: .82rem;
  width: 100%;
  outline: none;
  transition: border-color .15s, box-shadow .15s;
}

input:focus,
select:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(88,166,255,.12);
}

select option { background: var(--surface); color: var(--text); }

/* Dataset rows */
.datasets-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.datasets-header label {
  font-size: .74rem;
  color: var(--muted);
  font-weight: 500;
}

.datasets-header button {
  font-size: .74rem;
  padding: 4px 10px;
  border-radius: 6px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--accent);
  cursor: pointer;
  transition: background .15s;
}

.datasets-header button:hover { background: rgba(88,166,255,.1); }

#dataset-rows { display: flex; flex-direction: column; gap: 10px; }

.dataset-row {
  display: flex;
  gap: 10px;
  align-items: flex-start;
  padding: 12px;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  transition: border-color .15s;
}

.dataset-row:focus-within { border-color: rgba(88,166,255,.35); }

.ds-color-wrap { flex-shrink: 0; padding-top: 20px; }

.ds-color-wrap input[type="color"] {
  width: 30px;
  height: 30px;
  border: 2px solid var(--border);
  border-radius: 6px;
  cursor: pointer;
  background: none;
  padding: 2px;
}

.ds-fields { flex: 1; min-width: 0; }

.ds-remove-wrap { flex-shrink: 0; padding-top: 20px; }

/* Help button */
.help-btn {
  background: none;
  border: none;
  cursor: pointer;
  font-size: .78rem;
  padding: 0 2px;
  opacity: .55;
  transition: opacity .15s;
  line-height: 1;
}

.help-btn:hover { opacity: 1; }

/* Help content */
.help-section { margin-bottom: 16px; }
.help-section:last-child { margin-bottom: 0; }
.help-section h3 { font-size: .82rem; font-weight: 600; margin-bottom: 6px; color: var(--text); }
.help-section p  { font-size: .78rem; color: var(--muted); line-height: 1.65; }

.help-example {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 5px;
  padding: 8px 12px;
  font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
  font-size: .74rem;
  color: var(--accent);
  margin-top: 8px;
  line-height: 1.7;
}

/* ── Toast notifications ──────────────────────────────── */
#toast-container {
  position: fixed;
  bottom: 20px;
  right: 20px;
  z-index: 400;
  display: flex;
  flex-direction: column-reverse;
  gap: 8px;
  max-width: 370px;
  pointer-events: none;
}

.toast {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 14px;
  border-radius: var(--radius);
  border: 1px solid var(--border);
  background: var(--surface);
  box-shadow: var(--shadow);
  font-size: .8rem;
  color: var(--text);
  opacity: 0;
  transform: translateX(16px);
  transition: opacity .22s ease, transform .22s ease;
  pointer-events: auto;
  max-width: 370px;
  word-break: break-word;
}

.toast.toast-visible {
  opacity: 1;
  transform: translateX(0);
}

.toast-info  { border-left: 3px solid var(--accent); }
.toast-ok    { border-left: 3px solid var(--green); }
.toast-warn  { border-left: 3px solid var(--yellow); }
.toast-error { border-left: 3px solid var(--red); }

.toast-icon { font-size: .9rem; flex-shrink: 0; margin-top: 1px; }
.toast-msg  { flex: 1; line-height: 1.45; }

.toast-close {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--muted);
  font-size: .8rem;
  padding: 0;
  flex-shrink: 0;
  margin-top: 1px;
  transition: color .15s;
}

.toast-close:hover { color: var(--text); }

/* ── Scrollbar ────────────────────────────────────────── */
::-webkit-scrollbar       { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }

/* ── Responsive ───────────────────────────────────────── */
@media (max-width: 680px) {
  #widget-grid { grid-template-columns: 1fr; padding: 12px; gap: 12px; }
  .brand-sub, .ros-status span { display: none; }
  .form-row { flex-direction: column; }
  .ds-color-wrap, .ds-remove-wrap { padding-top: 0; }
  .dataset-row { flex-wrap: wrap; }
  .header-right gap { gap: 8px; }
}
